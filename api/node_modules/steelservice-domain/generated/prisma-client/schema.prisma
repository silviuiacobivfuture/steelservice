//// # Datasource # ////

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
  output          = "../prisma-client"
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "../dbml"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//// # Enums # ////

enum AssetType {
  product_image
  quote_documentation
  invoice
}

enum QuoteStatus {
  draft
  analysis
  offer
  accepted
  pending
  delivered
}

enum ActionType {
  Created
  Updated
  Deleted
}

enum TargetType {
  Asset
  CalculatorFormula
  Country
  Currency
  Customer
  MeasurementUnit
  Profile
  Quote
  QuoteType
  QuoteeInput
  RequestMessage
  Role
  Service
  TechnicalAttribute
  User
  UserCustomer
  UserRole
}

model Asset {
  id       String    @id @default(uuid())
  type     AssetType
  assetUrl String    @db.Text

  productAssets ProductAsset[]
  quoteAssets   QuoteAsset[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  quote Quote? @relation("QuoteInvoice")
}

model CalculatorFormula {
  id          String  @id @default(uuid())
  name        String  @db.Text
  description String? @db.Text
  calculates  String  @db.Text
  formula     String  @db.Text

  products Product[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([name], name: "unique_calculator_formula_name")
}

model Country {
  id   String @id @default(uuid())
  name String @unique @db.Text

  regions  Region[]
  profiles Profile[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model Customer {
  id          String  @id @default(uuid())
  description String? @db.Text

  userCustomers UserCustomer[]
  quotes        Quote[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model EntityType {
  id   String @id @default(uuid())
  name String @unique @db.Text

  profiles Profile[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model Material {
  id   String @id @default(uuid())
  name String @db.Text

  attributes TechnicalAttributeMaterial[]
  products   Product[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([name], name: "unique_material_name")
}

model MeasurementUnit {
  id         String               @id @default(uuid())
  unit       String               @db.VarChar(20)
  attributes TechnicalAttribute[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@index([unit], name: "idx_measurement_unit_unit")
}

model Product {
  id          String             @id @default(uuid())
  description String?            @db.Text
  formulaId   String?
  formula     CalculatorFormula? @relation(fields: [formulaId], references: [id])
  materialId  String
  material    Material           @relation(fields: [materialId], references: [id])

  images                       ProductAsset[]
  attributes                   TechnicalAttributeProduct[]
  services                     ProductService[]
  productQuotes                ProductQuote[]
  quoteeProductServices        QuoteeProductService[]
  quoteProductAttributeQuotees QuoteProductAttributeQuotee[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model Profile {
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName    String     @db.Text
  lastName     String     @db.Text
  email        String     @unique @db.Text
  phoneNumber  String     @db.Text
  addressOne   String     @db.Text
  addressTwo   String?    @db.Text
  postalCode   String     @db.Text
  entityTypeId String
  entityType   EntityType @relation(fields: [entityTypeId], references: [id])
  countryId    String
  country      Country    @relation(fields: [countryId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model Quote {
  id            String      @id @default(uuid())
  clientId      String
  client        User        @relation("QuoteClient", fields: [clientId], references: [id])
  agentId       String?
  agent         User?       @relation("QuoteAgent", fields: [agentId], references: [id])
  typeId        String
  type          QuoteType   @relation(fields: [typeId], references: [id])
  invoiceId     String?     @unique
  invoice       Asset?      @relation("QuoteInvoice", fields: [invoiceId], references: [id])
  quoteeInputId String      @unique
  quoteeInput   QuoteeInput @relation(fields: [quoteeInputId], references: [id])
  forCustomerId String?
  forCustomer   Customer?   @relation(fields: [forCustomerId], references: [id])
  status        QuoteStatus @default(draft)
  chatRoomId    String?     @db.Text

  products                ProductQuote[]
  images                  QuoteAsset[]                  @relation("QuoteImages")
  technicalDocuments      QuoteAsset[]                  @relation("QuoteTechnicalDocuments")
  quoteeSelectedServices  QuoteeProductService[]
  quoteProductInputValues QuoteProductAttributeQuotee[]
  requests                RequestMessage[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model QuoteType {
  id   String @id @default(uuid())
  name String @db.Text

  quotes Quote[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([name], name: "unique_quote_type_name")
}

model QuoteeInput {
  id                      String  @id @default(uuid())
  comment                 String? @db.Text
  quoteeInternalReference String? @db.Text

  quote Quote?

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model Region {
  id        String  @id @default(uuid())
  name      String  @db.Text
  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([name, countryId], name: "unique_region_country")
}

model RequestMessage {
  id        String  @id @default(uuid())
  message   String  @db.Text
  satisfied Boolean @default(false)
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model Role {
  id   String @id @default(uuid())
  name String @unique @db.Text

  userRoles UserRole[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?
}

model Service {
  id   String @id @default(uuid())
  name String @db.Text

  productServices       ProductService[]
  quoteeProductServices QuoteeProductService[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([name], name: "unique_service_name")
}

model TechnicalAttribute {
  id              String          @id @default(uuid())
  name            String          @db.Text
  var             String          @db.VarChar(20)
  unitId          String
  unit            MeasurementUnit @relation(fields: [unitId], references: [id])
  selectionValues String[]        @default([])

  productAttributes  TechnicalAttributeProduct[]
  materialAttributes TechnicalAttributeMaterial[]

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([var], name: "unique_technical_attribute_var")
  @@index([var], name: "idx_technical_attribute_var")
}

model User {
  id     String  @id @default(uuid())
  banned Boolean @default(false)

  roles     UserRole[]
  profile   Profile?
  customers UserCustomer[]

  // Existing relations
  actions UserAction[] @relation("UserActions")

  // Added reciprocal relations
  clientQuotes Quote[] @relation("QuoteClient")
  agentQuotes  Quote[] @relation("QuoteAgent")

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAction {
  id         Int        @id @default(autoincrement())
  actionType ActionType
  user       User       @relation("UserActions", fields: [userId], references: [id])
  userId     String // Changed from Int to String to match User.id
  targetType String // The name of the target model, e.g., "Product"
  targetId   Int // ID of the target record in the specific model
  timestamp  DateTime   @default(now())
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([userId, roleId], name: "unique_user_role")
}

model ProductAsset {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  assetId   String
  asset     Asset   @relation(fields: [assetId], references: [id])

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, assetId], name: "unique_product_asset")
}

model ProductQuote {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id])
  quantity  Int
  comment   String? @db.Text

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([productId, quoteId], name: "unique_product_quote")
}

model ProductService {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([productId, serviceId], name: "unique_product_service")
}

model QuoteAsset {
  id                        String  @id @default(uuid())
  quoteId                   String
  quoteImages               Quote   @relation("QuoteImages", fields: [quoteId], references: [id])
  technicalDocumentsQuoteId String?
  technicalDocuments        Quote?  @relation("QuoteTechnicalDocuments", fields: [technicalDocumentsQuoteId], references: [id])
  assetId                   String
  asset                     Asset   @relation(fields: [assetId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([quoteId, assetId], name: "unique_quote_asset")
}

model QuoteProductAttributeQuotee {
  id                 String  @id @default(uuid())
  quoteId            String
  quote              Quote   @relation(fields: [quoteId], references: [id])
  productId          String
  product            Product @relation(fields: [productId], references: [id])
  quoteeProductInput Json?

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([quoteId, productId], name: "unique_quote_product_attribute_quotee")
}

model QuoteeProductService {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id])
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([productId, quoteId, serviceId], name: "unique_quotee_product_service")
}

model TechnicalAttributeMaterial {
  id          String             @id @default(uuid())
  materialId  String
  material    Material           @relation(fields: [materialId], references: [id])
  attributeId String
  attribute   TechnicalAttribute @relation(fields: [attributeId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([materialId, attributeId], name: "unique_material_attribute")
}

model TechnicalAttributeProduct {
  id                     String             @id @default(uuid())
  insertableForQuotation Boolean            @default(false)
  productId              String
  product                Product            @relation(fields: [productId], references: [id])
  attributeId            String
  attribute              TechnicalAttribute @relation(fields: [attributeId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([productId, attributeId], name: "unique_product_attribute")
}

model UserCustomer {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Audit fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedById String?

  @@unique([userId, customerId], name: "unique_user_customer")
}
